{
  "name": "lsp-workspace",
  "version": "2.0.6",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run --workspaces build",
    "test": "npm run --workspaces test",
    "lint": "npm run lint:eslint && npm -w @lsp/compiler run lint",
    "lint:eslint": "eslint \"packages/**/*.{ts,mts,cts}\"",
    "clean": "npm run --workspaces clean",
    "typecheck": "npm run --workspaces typecheck",
    "version:sync": "node scripts/sync-version.mjs",
    "version:check": "node scripts/check-version.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.3.0",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@types/vscode": "^1.120.0",
    "esbuild": "^0.28.0"
  }
}
