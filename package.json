{
  "name": "lsp-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run --workspaces build",
    "test": "npm run --workspaces test",
    "lint": "npm run lint:eslint && npm -w @lsp/compiler run lint",
    "lint:eslint": "eslint \"packages/**/*.{ts,mts,cts}\" \"scripts/**/*.{ts,mts,cts,mjs}\"",
    "clean": "npm run --workspaces clean",
    "typecheck": "npm run --workspaces typecheck"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.3.0",
    "globals": "^17.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@types/vscode": "^1.118.0",
    "esbuild": "^0.28.0"
  }
}
